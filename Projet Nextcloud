<!DOCTYPE html>
<html lang="fr">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Guide Nextcloud — Installation complète | Mervyn Sainfranc</title>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link href="https://fonts.googleapis.com/css2?family=Space+Mono:wght@400;700&family=Inter:wght@300;400;500;600;700&display=swap" rel="stylesheet">
  <style>
    :root {
      --bg: #ffffff;
      --bg1: #f8f9fa;
      --bg2: #f1f3f5;
      --bg3: #e9ecef;
      --line: #dee2e6;
      --primary: #2563eb;
      --primary-light: #3b82f6;
      --success: #10b981;
      --warning: #f59e0b;
      --danger: #ef4444;
      --text: #212529;
      --text2: #6c757d;
      --text3: #adb5bd;
      --mono: 'Space Mono', monospace;
      --sans: 'Inter', sans-serif;
    }

    * {
      margin: 0;
      padding: 0;
      box-sizing: border-box;
    }

    html {
      background: var(--bg);
      color: var(--text);
      font-family: var(--sans);
      scroll-behavior: smooth;
    }

    body {
      overflow-x: hidden;
    }

    /* TOP BAR */
    .topbar {
      position: sticky;
      top: 0;
      z-index: 100;
      background: rgba(255, 255, 255, 0.95);
      backdrop-filter: blur(12px);
      border-bottom: 1px solid var(--line);
      padding: 0 40px;
      height: 60px;
      display: flex;
      align-items: center;
      justify-content: space-between;
    }

    .topbar-left {
      display: flex;
      align-items: center;
      gap: 16px;
    }

    .topbar-logo {
      font-family: var(--mono);
      font-size: 13px;
      color: var(--primary);
    }

    .topbar-sep {
      color: var(--text3);
    }

    .topbar-title {
      font-size: 14px;
      color: var(--text2);
      font-weight: 500;
    }

    .topbar-back {
      font-family: var(--mono);
      font-size: 12px;
      color: var(--primary);
      text-decoration: none;
      border: 1px solid var(--primary);
      padding: 6px 14px;
      border-radius: 6px;
      transition: all 0.2s;
    }

    .topbar-back:hover {
      background: var(--primary);
      color: white;
    }

    /* LAYOUT */
    .layout {
      display: flex;
      min-height: calc(100vh - 60px);
    }

    /* SIDEBAR */
    .sidebar {
      width: 280px;
      flex-shrink: 0;
      border-right: 1px solid var(--line);
      padding: 32px 0;
      position: sticky;
      top: 60px;
      height: calc(100vh - 60px);
      overflow-y: auto;
      background: var(--bg);
    }

    .sidebar-section {
      margin-bottom: 28px;
    }

    .sidebar-label {
      font-family: var(--mono);
      font-size: 10px;
      color: var(--text3);
      text-transform: uppercase;
      letter-spacing: 0.15em;
      padding: 0 24px;
      margin-bottom: 8px;
    }

    .sidebar-link {
      display: flex;
      align-items: center;
      gap: 10px;
      padding: 8px 24px;
      font-size: 13px;
      color: var(--text2);
      text-decoration: none;
      transition: all 0.15s;
      border-left: 2px solid transparent;
    }

    .sidebar-link:hover, .sidebar-link.active {
      color: var(--primary);
      background: rgba(37, 99, 235, 0.06);
      border-left-color: var(--primary);
    }

    .sidebar-link .step-num {
      font-family: var(--mono);
      font-size: 10px;
      width: 20px;
      height: 20px;
      border-radius: 4px;
      background: var(--bg2);
      display: flex;
      align-items: center;
      justify-content: center;
      flex-shrink: 0;
      color: var(--text3);
    }

    /* CONTENT */
    .content {
      flex: 1;
      padding: 48px 60px;
      max-width: 900px;
      background: var(--bg);
    }

    /* HERO DOC */
    .doc-hero {
      background: linear-gradient(135deg, rgba(37, 99, 235, 0.08) 0%, rgba(255, 255, 255, 0) 60%);
      border: 1px solid rgba(37, 99, 235, 0.2);
      border-radius: 16px;
      padding: 40px 48px;
      margin-bottom: 60px;
      position: relative;
      overflow: hidden;
    }

    .doc-hero::before {
      content: '☁';
      position: absolute;
      right: 40px;
      top: 20px;
      font-size: 120px;
      opacity: 0.05;
      color: var(--primary);
    }

    .doc-hero-tag {
      font-family: var(--mono);
      font-size: 11px;
      color: var(--primary);
      letter-spacing: 0.12em;
      text-transform: uppercase;
      margin-bottom: 12px;
    }

    .doc-hero h1 {
      font-size: 36px;
      font-weight: 700;
      line-height: 1.15;
      margin-bottom: 16px;
      color: var(--text);
    }

    .doc-hero-desc {
      color: var(--text2);
      font-size: 15px;
      line-height: 1.75;
      max-width: 560px;
      margin-bottom: 28px;
    }

    .doc-meta {
      display: flex;
      gap: 20px;
      flex-wrap: wrap;
    }

    .doc-meta-item {
      display: flex;
      align-items: center;
      gap: 8px;
      font-family: var(--mono);
      font-size: 11px;
      color: var(--text3);
    }

    .doc-meta-item span {
      color: var(--text2);
    }

    /* INFO BOXES */
    .box {
      border-radius: 8px;
      padding: 16px 20px;
      margin: 20px 0;
      font-size: 14px;
      line-height: 1.7;
      border-left: 3px solid;
      background: var(--bg1);
    }

    .box-info {
      border-color: var(--primary);
      color: var(--text2);
    }
    .box-warn {
      border-color: var(--warning);
      color: var(--text2);
    }
    .box-danger {
      border-color: var(--danger);
      color: var(--text2);
    }
    .box-success {
      border-color: var(--success);
      color: var(--text2);
    }

    .box strong {
      color: var(--text);
    }

    /* STEP SECTIONS */
    .step-section {
      margin-bottom: 64px;
      scroll-margin-top: 80px;
    }

    .step-header {
      display: flex;
      align-items: center;
      gap: 16px;
      margin-bottom: 24px;
      padding-bottom: 16px;
      border-bottom: 1px solid var(--line);
    }

    .step-badge {
      font-family: var(--mono);
      font-size: 11px;
      font-weight: 700;
      width: 36px;
      height: 36px;
      border-radius: 8px;
      background: rgba(37, 99, 235, 0.12);
      color: var(--primary);
      display: flex;
      align-items: center;
      justify-content: center;
      flex-shrink: 0;
    }

    .step-title {
      font-size: 22px;
      font-weight: 700;
      color: var(--text);
    }

    .step-subtitle {
      font-size: 14px;
      color: var(--text2);
      margin-top: 2px;
    }

    /* CODE BLOCKS */
    .code-block {
      background: var(--bg1);
      border: 1px solid var(--line);
      border-radius: 10px;
      overflow: hidden;
      margin: 16px 0;
    }

    .code-header {
      display: flex;
      align-items: center;
      justify-content: space-between;
      padding: 10px 16px;
      background: var(--bg2);
      border-bottom: 1px solid var(--line);
    }

    .code-label {
      font-family: var(--mono);
      font-size: 11px;
      color: var(--text3);
      display: flex;
      align-items: center;
      gap: 8px;
    }

    .code-label .dot {
      width: 8px;
      height: 8px;
      border-radius: 50%;
      background: var(--success);
    }

    .code-copy {
      font-family: var(--mono);
      font-size: 11px;
      color: var(--text3);
      background: none;
      border: 1px solid var(--line);
      padding: 3px 10px;
      border-radius: 4px;
      cursor: pointer;
      transition: all 0.15s;
    }

    .code-copy:hover {
      color: var(--text);
      border-color: var(--text3);
    }

    .code-copy.copied {
      color: var(--success);
      border-color: var(--success);
    }

    pre {
      padding: 20px;
      font-family: var(--mono);
      font-size: 13px;
      line-height: 1.7;
      overflow-x: auto;
      color: var(--text);
      background: var(--bg);
    }

    /* Syntax Highlighting */
    .c-comment { color: var(--text3); font-style: italic; }
    .c-cmd { color: #2563eb; }
    .c-string { color: #16a34a; }
    .c-flag { color: #d97706; }
    .c-path { color: #059669; }
    .c-section { color: var(--primary); font-weight: 700; }
    .c-var { color: #8b5cf6; }
    .c-ok { color: var(--success); }

    /* INLINE CODE */
    code {
      font-family: var(--mono);
      font-size: 12.5px;
      background: var(--bg2);
      border: 1px solid var(--line);
      border-radius: 4px;
      padding: 1px 6px;
      color: #d97706;
    }

    /* PROSE */
    p {
      font-size: 15px;
      color: var(--text2);
      line-height: 1.8;
      margin-bottom: 16px;
    }

    h3 {
      font-size: 16px;
      font-weight: 600;
      color: var(--text);
      margin: 28px 0 12px;
    }

    /* CHECKLIST */
    .checklist {
      display: flex;
      flex-direction: column;
      gap: 10px;
      margin: 16px 0;
    }

    .check-item {
      display: flex;
      align-items: flex-start;
      gap: 12px;
      padding: 12px 16px;
      background: var(--bg1);
      border: 1px solid var(--line);
      border-radius: 8px;
      font-size: 14px;
      color: var(--text2);
    }

    .check-icon {
      width: 20px;
      height: 20px;
      border-radius: 50%;
      display: flex;
      align-items: center;
      justify-content: center;
      font-size: 11px;
      flex-shrink: 0;
      margin-top: 1px;
    }

    .check-icon.ok {
      background: rgba(16, 185, 129, 0.15);
      color: var(--success);
    }
    .check-icon.warn {
      background: rgba(245, 158, 11, 0.15);
      color: var(--warning);
    }

    /* INFRA DIAGRAM */
    .infra-diagram {
      background: var(--bg1);
      border: 1px solid var(--line);
      border-radius: 12px;
      padding: 32px;
      margin: 20px 0;
      font-family: var(--mono);
      font-size: 13px;
      line-height: 1.9;
      color: var(--text2);
    }

    .infra-diagram .d-title {
      color: var(--primary);
      font-size: 11px;
      letter-spacing: 0.1em;
      text-transform: uppercase;
      margin-bottom: 16px;
    }

    .infra-diagram .d-node {
      color: var(--text);
      font-weight: 700;
    }

    .infra-diagram .d-arrow { color: var(--text3); }
    .infra-diagram .d-detail { color: var(--text3); font-style: italic; }

    /* TABLE */
    table {
      width: 100%;
      border-collapse: collapse;
      margin: 16px 0;
      font-size: 13px;
    }

    th {
      background: var(--bg2);
      color: var(--text);
      font-weight: 600;
      padding: 10px 16px;
      text-align: left;
      border: 1px solid var(--line);
      font-family: var(--mono);
      font-size: 11px;
      letter-spacing: 0.05em;
    }

    td {
      padding: 10px 16px;
      border: 1px solid var(--line);
      color: var(--text2);
    }

    tr:nth-child(even) td {
      background: rgba(241, 243, 245, 0.4);
    }

    /* PROGRESS TRACKER */
    .progress-tracker {
      display: flex;
      gap: 6px;
      margin-bottom: 40px;
      flex-wrap: wrap;
    }

    .progress-step {
      font-family: var(--mono);
      font-size: 10px;
      padding: 4px 10px;
      border-radius: 20px;
      border: 1px solid var(--line);
      color: var(--text3);
      text-decoration: none;
      transition: all 0.15s;
    }

    .progress-step:hover {
      border-color: var(--primary);
      color: var(--primary);
    }

    /* RESPONSIVE */
    @media (max-width: 900px) {
      .sidebar { display: none; }
      .content { padding: 32px 20px; }
      .topbar { padding: 0 20px; }
    }
  </style>
</head>
